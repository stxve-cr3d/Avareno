AVARENO_REQUIRE_AUTH=1
AVARENO_ENV=production
AVARENO_APP_URL=https://avareno.app
AVARENO_DB_PATH=/data/avareno.db
AVARENO_UPLOAD_ROOT=/data/uploads
AVARENO_ENABLE_STATIC_UPLOADS=false
AVARENO_MAX_UPLOAD_BYTES=10485760
AVARENO_SIGNED_URL_SECRET=replace-with-a-long-random-server-side-secret
AVARENO_SIGNED_URL_TTL_SECONDS=300
# Encrypts stored provider tokens (Home Assistant). Without it, connector
# setup refuses to store credentials rather than falling back to plaintext.
AVARENO_CONNECTOR_SECRET_KEY=replace-with-a-long-random-server-side-secret
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-public-publishable-key
# Optional local HS256 verification for legacy/shared-secret projects.
SUPABASE_JWT_SECRET=server-side-supabase-jwt-secret
SUPABASE_JWT_AUDIENCE=authenticated
AVARENO_CORS_ORIGINS=https://avareno.app,https://www.avareno.app

# Local Avareno Bridge MVP. Development only; direct bridge polling is blocked in production.
AVARENO_ENABLE_LOCAL_BRIDGE=false
AVARENO_BRIDGE_URL=http://127.0.0.1:8765

AUTH_EMAIL_FROM=noreply@avareno.de
AUTH_EMAIL_FROM_NAME=Avareno
AUTH_EMAIL_REPLY_TO=info@avareno.de
AUTH_SUPPORT_EMAIL=info@avareno.de

# Stripe billing. Keep all secret keys and Price IDs server-side.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PERSONAL_MONTHLY=
STRIPE_PRICE_PERSONAL_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_FAMILY_MONTHLY=
STRIPE_PRICE_FAMILY_YEARLY=
STRIPE_CHECKOUT_SUCCESS_URL=
STRIPE_CHECKOUT_CANCEL_URL=
STRIPE_EMBEDDED_CHECKOUT_RETURN_URL=
STRIPE_BILLING_PORTAL_RETURN_URL=
STRIPE_CHECKOUT_LOCALE=de
