AVARENO_REQUIRE_AUTH=1
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-public-publishable-key
# Optional local HS256 verification for legacy/shared-secret projects.
SUPABASE_JWT_SECRET=server-side-supabase-jwt-secret
SUPABASE_JWT_AUDIENCE=authenticated
AVARENO_CORS_ORIGINS=https://avareno.de,https://app.avareno.de

AUTH_EMAIL_FROM=noreply@avareno.de
AUTH_EMAIL_FROM_NAME=Avareno
AUTH_EMAIL_REPLY_TO=info@avareno.de
AUTH_SUPPORT_EMAIL=info@avareno.de
