AVARENO_REQUIRE_AUTH=1
AVARENO_ENABLE_STATIC_UPLOADS=false
AVARENO_MAX_UPLOAD_BYTES=10485760
AVARENO_SIGNED_URL_SECRET=replace-with-a-long-random-server-side-secret
AVARENO_SIGNED_URL_TTL_SECONDS=300
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-public-publishable-key
# Optional local HS256 verification for legacy/shared-secret projects.
SUPABASE_JWT_SECRET=server-side-supabase-jwt-secret
SUPABASE_JWT_AUDIENCE=authenticated
AVARENO_CORS_ORIGINS=https://avareno.de,https://app.avareno.de

AUTH_EMAIL_FROM=noreply@avareno.de
AUTH_EMAIL_FROM_NAME=Avareno
AUTH_EMAIL_REPLY_TO=info@avareno.de
AUTH_SUPPORT_EMAIL=info@avareno.de

# Billing foundation. Keep all Paddle secrets server-side.
# Do not add Paddle API keys or webhook secrets to frontend env files.
PADDLE_ENVIRONMENT=sandbox
PADDLE_API_KEY=your-server-side-paddle-api-key
PADDLE_WEBHOOK_SECRET=your-paddle-webhook-secret
PADDLE_PERSONAL_PRICE_ID=pri_personal_monthly_price_id
PADDLE_FAMILY_PRICE_ID=pri_family_monthly_price_id
AVARENO_FAMILY_BILLING_ENABLED=false
PADDLE_CHECKOUT_SUCCESS_URL=https://app.avareno.de/app/settings
PADDLE_BILLING_PORTAL_URL=
