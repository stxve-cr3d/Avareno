VITE_AUTH_PROVIDER=supabase
VITE_BETA_INVITE_ONLY=true
VITE_ENABLE_RECEIPT_EXTRACTION=false
VITE_ENABLE_DOCUMENT_PROCESSING=false
VITE_ENABLE_OAUTH=false
VITE_ENABLE_HOUSEHOLD_SHARING=false
VITE_ENABLE_PUBLIC_DOCUMENT_LINKS=false
VITE_ENABLE_INLINE_DOCUMENT_PREVIEW=false
VITE_ENABLE_BILLING=false
VITE_ENABLE_DOCUMENT_UPLOADS=true
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-public-publishable-key
# Legacy Supabase projects may still use VITE_SUPABASE_ANON_KEY.
# VITE_SUPABASE_ANON_KEY=your-public-anon-key
VITE_AUTH_REDIRECT_URL=http://127.0.0.1:5173/auth/callback
VITE_AUTH_EMAIL_REDIRECT_URL=http://127.0.0.1:5173/auth/callback
VITE_AUTH_PASSWORD_RESET_URL=http://127.0.0.1:5173/reset-password
VITE_AUTH_GOOGLE_ENABLED=false
VITE_AUTH_APPLE_ENABLED=false
VITE_AUTH_PHONE_ENABLED=false
VITE_AUTH_PASSKEY_ENABLED=false
VITE_AUTH_TURNSTILE_ENABLED=false
VITE_TURNSTILE_SITE_KEY=your-cloudflare-turnstile-site-key
VITE_AUTH_EMAIL_FROM=noreply@avareno.de
VITE_AUTH_EMAIL_FROM_NAME=Avareno
VITE_AUTH_EMAIL_REPLY_TO=info@avareno.de
VITE_AUTH_SUPPORT_EMAIL=info@avareno.de
VITE_STRIPE_PUBLISHABLE_KEY=
# Legacy alias, prefer VITE_STRIPE_PUBLISHABLE_KEY for this Vite app.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Local UI-only development escape hatch. Do not use in production.
# VITE_AUTH_PROVIDER=mock
