# Backend API (FastAPI on Fly.io). For local backend testing from a phone use
# your machine's LAN IP, e.g. http://192.168.1.20:8000 — localhost won't work.
EXPO_PUBLIC_API_ORIGIN=https://avareno-api.fly.dev

# Same Supabase project as frontend/.env.local (publishable key, safe to expose).
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
